---
import { Home } from "lucide-react";
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Pagina no encontrada | Felipe Arce" description="The requested page could not be found." canonicalPath="/404">
  <main class="relative flex min-h-[60vh] flex-col items-center justify-center gap-6 overflow-hidden text-center">
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center text-[12rem] font-bold leading-none text-muted/30 sm:text-[18rem]">
      404
    </div>
    <div class="relative z-10 flex flex-col items-center gap-3">
      <h1 class="text-3xl font-semibold tracking-tighter sm:text-5xl">Pagina no encontrada</h1>
      <p class="max-w-md text-muted-foreground">La página que estás buscando no existe o ha sido movida.</p>
      <a href="/" class="mt-2 inline-flex h-9 items-center justify-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-primary-foreground shadow hover:bg-primary/90">
        <Home className="size-4" aria-hidden /> Inicio
      </a>
    </div>
  </main>
</Layout>
